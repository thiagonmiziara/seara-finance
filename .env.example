# ─── Frontend (Vite) — exposed to the browser ──────────────────────────────
# All VITE_* variables ARE included in the bundle. Never put secrets here.

# Firebase (Authentication only)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Supabase (Postgres + Edge Functions)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Edge Functions / Server-side only — set via `supabase secrets set` ─────
# DO NOT prefix with VITE_. These never reach the browser.

# Required so firebase-jwt.ts can verify ID Tokens issued by your project.
FIREBASE_PROJECT_ID=

# Service role for the Edge Functions (auto-injected when using `supabase
# functions deploy`, but listed here for clarity).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Evolution API (WhatsApp gateway)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
EVOLUTION_WEBHOOK_SECRET=

# Worker tunables (optional)
NOTIFICATIONS_BATCH=25
NOTIFICATIONS_MAX_ATTEMPTS=3

# ─── Stripe ─────────────────────────────────────────────────────────────────
# Server-side (Edge Functions). NEVER expose STRIPE_SECRET_KEY to the browser.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs criados no Dashboard da Stripe (Products → Prices). Usados pelo
# stripe-checkout para resolver o plan → price.
STRIPE_PRICE_PRO_MONTH=
STRIPE_PRICE_PRO_YEAR=

# URL pública do front (usada para success_url / cancel_url / return_url).
APP_URL=http://localhost:5173
