# Copy to .env (gitignored) and fill in.

# ─── Evolution API (local) ──────────────────────────────────────────────────
EVOLUTION_API_KEY=change-me-to-a-random-32-char-string
EVOLUTION_INSTANCE=dev

# ─── Postgres credentials (only inside docker network) ──────────────────────
POSTGRES_USER=evolution
POSTGRES_PASSWORD=evolution
POSTGRES_DB=evolution

# ─── Gemini (Google) — bot usa pra parse de texto/áudio/foto ────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ─── Supabase (bot usa service role pra resolver phone → user_id e gravar) ──
SUPABASE_URL=https://vuhbbxtxpewsjajmjost.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
